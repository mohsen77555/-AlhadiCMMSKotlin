rules_version = '2';

// Al-Hadi CMMS — Firestore security rules.
//
// The app signs every user in to Firebase Authentication (a synthetic username@alhadi.local email,
// handled transparently by FirebaseAuthGateway), so these rules require an authenticated session for
// all access. This replaces open "Test mode" and is safe to deploy.
//
// Role-based authorization (manager vs. technician vs. warehouse, etc.) is enforced inside the app
// (AccessControl.kt + navigation gating). Enforcing roles in the rules themselves would require a
// trusted uid->role mapping via Firebase custom claims, which can only be set from a privileged
// backend (Admin SDK / Cloud Function) — not from the client. That is the recommended next step if
// server-side role enforcement is needed; until then, authentication is the security boundary here.
//
// Deploy via the Firebase console (Firestore Database -> Rules) or
// `firebase deploy --only firestore:rules`. After deploying, turn OFF Test mode.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Every synced collection requires an authenticated user for both reads and writes.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
